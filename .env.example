# ==============================================================================
# Snake Species Identifier - Backend Environment Configuration Template
# Copy this file to '.env' and modify settings for your specific deployment.
# ==============================================================================

# API Configurations
# ------------------
# The title of the FastAPI application.
# API_TITLE=Snake Species Identifier API

# The version of the FastAPI application.
# API_VERSION=1.0.0

# Run the FastAPI application in debug/development mode (boolean: true/false).
# DEBUG=false

# Model Configurations
# --------------------
# The absolute or relative path to the trained TensorFlow/Keras (.keras) classification model file.
# MODEL_PATH=models/snake_classifier.keras

# The absolute or relative path to the JSON file containing the indexed list of snake species class names.
# CLASS_NAMES_PATH=models/class_names.json

# Image Processing & Upload Configurations
# ----------------------------------------
# Maximum allowed size for uploaded files in bytes (default: 5242880 bytes = 5MB).
# MAX_UPLOAD_SIZE=5242880

# Allowed MIME types for uploaded image files (comma-separated or JSON list).
# ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# The target dimensions (height, width) to which images will be resized before classification.
# IMAGE_SIZE=224,224

# The confidence threshold (float between 0.0 and 1.0) above which predictions are considered reliable.
# CONFIDENCE_THRESHOLD=0.60

# Network & Logging Configurations
# --------------------------------
# Allowed origins for CORS (comma-separated or JSON list of URLs, or "*" to allow all).
# CORS_ORIGINS=*

# The logging severity level for standard out (options: DEBUG, INFO, WARNING, ERROR, CRITICAL).
# LOGGING_LEVEL=INFO

# Groq Enrichment Configurations
# ------------------------------
# The API key required to connect to the Groq cloud service (keep secret, do not commit).
# GROQ_API_KEY=
# The specific LLM model used to fetch species herpetology data.
# GROQ_MODEL=llama-3.3-70b-versatile
# Flag to enable/disable the optional Groq species enrichment layer (boolean: true/false).
# GROQ_ENRICHMENT_ENABLED=true
# Timeout in seconds for requests to the Groq API.
# GROQ_TIMEOUT=10.0
